# Example environment variable overrides for the backend
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=PatientPortalDb;Trusted_Connection=True;MultipleActiveResultSets=true
AuthSettings__Issuer=PatientPortal
AuthSettings__Audience=PatientPortalUsers
AuthSettings__SigningKey=ReplaceWithSecureSigningKey
AuthSettings__AccessTokenExpirationMinutes=60
AuthSettings__RefreshTokenExpirationDays=30
