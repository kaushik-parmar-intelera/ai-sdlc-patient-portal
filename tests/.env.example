# Environment: qa | staging | prod
ENV=qa

# Platform: web | android | ios
PLATFORM=web

# Cloud execution: local | lambdatest
CLOUD=local

# LambdaTest credentials (required when CLOUD=lambdatest)
LT_USERNAME=your_lambdatest_username
LT_ACCESS_KEY=your_lambdatest_access_key

# Appium server (local)
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# App paths (local execution) — set to built APK/IPA from MyApp
# For Expo development: leave blank and use Expo Go, or build first:
#   cd /Users/sanjay.singh/Downloads/Test2/MyApp && npx expo run:android
ANDROID_APP_PATH=
IOS_APP_PATH=

# Slack notifications (optional CI/CD)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
